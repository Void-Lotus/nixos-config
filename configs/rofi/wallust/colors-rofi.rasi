 /* wallust template - colors-rofi */

* {
active-background: #3F8A5B;
active-foreground: #D2F1DB;
normal-background: #1A1E1D;
normal-foreground: #D2F1DB;
urgent-background: #5C9E71;
urgent-foreground: #D2F1DB;

alternate-active-background: #39654B;
alternate-active-foreground: #D2F1DB;
alternate-normal-background: #1A1E1D;
alternate-normal-foreground: #D2F1DB;
alternate-urgent-background: #1A1E1D;
alternate-urgent-foreground: #D2F1DB;

selected-active-background: #3F8A5B;
selected-active-foreground: #1A1E1D;
selected-normal-background: #3F8A5B;
selected-normal-foreground: #1A1E1D;
selected-urgent-background: #39654B;
selected-urgent-foreground: #1A1E1D;

background-color: #1A1E1D;
background: rgba(0,0,0,0.7);
foreground: #D2F1DB;
border-color: #3F8A5B;

color0: #414443;
color1: #11211B;
color2: #224B34;
color3: #2B4C38;
color4: #2F6844;
color5: #457655;
color6: #5FA172;
color7: #B7E3C3;
color8: #809F88;
color9: #162C24;
color10: #2E6345;
color11: #39654B;
color12: #3F8A5B;
color13: #5C9E71;
color14: #7FD798;
color15: #B7E3C3;


}

